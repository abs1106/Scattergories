generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Answers {
  answer_id String  @id @db.Uuid
  game_id   String  @db.Uuid
  username  String?
  answer    String?
  Game      Game    @relation(fields: [game_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_answer_id")
}

model Game {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  room_code String?
  letter    String?  @db.Char
  topic     String?
  Answers   Answers[]
}
